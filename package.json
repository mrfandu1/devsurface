{
  "name": "devsurface",
  "version": "0.6.0",
  "description": "Zero-config local developer dashboard and CLI for Node.js, Python, Go, and Java repositories. Detect scripts, env files, ports, Docker services, frameworks, logs, and repo health.",
  "type": "module",
  "license": "MIT",
  "author": "mrfandu1",
  "keywords": [
    "developer-dashboard",
    "local-development",
    "nodejs",
    "cli",
    "developer-tools",
    "developer-productivity",
    "project-dashboard",
    "repository-health",
    "developer-onboarding",
    "repository-scanner",
    "npm-scripts",
    "task-runner",
    "docker-compose",
    "port-checker",
    "environment-checker",
    "github-action",
    "zero-config"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrfandu1/devsurface.git"
  },
  "bugs": {
    "url": "https://github.com/mrfandu1/devsurface/issues"
  },
  "homepage": "https://github.com/mrfandu1/devsurface#readme",
  "bin": {
    "devsurface": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "src/web/dist",
    "action.yml",
    "action/dist",
    "docs/devsurface-badge.svg",
    "docs/devsurface-demo.gif",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run build:web && npm run build:cli && npm run build:action",
    "build:action": "tsup src/action/index.ts --format esm --platform node --target node20 --clean --out-dir action/dist",
    "build:cli": "tsup src/cli/index.ts --format esm --dts --sourcemap --clean --out-dir dist/cli",
    "build:web": "vite build",
    "dev": "tsx src/cli/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.6",
    "hono": "^4.6.16",
    "picocolors": "^1.1.1",
    "ws": "^8.18.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "open": "^10.1.0",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=18.18"
  }
}
